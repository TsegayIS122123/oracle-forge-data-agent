OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_ROUTER_MODEL=google/gemini-2.0-flash-001
INJECTION_TEST_MODEL=anthropic/claude-sonnet-4

# Flask: leave FLASK_DEBUG unset for fast single-process server (no reloader). Set FLASK_DEBUG=1 only when editing code.
# FLASK_DEBUG=1
# PORT=8080
# FLASK_HOST=0.0.0.0

# Optional: run duckdb-local queries via MotherDuck (md:) with ATTACH + USE — same pattern as yelp-analytics.
# DUCKDB_LOCAL_USE_MOTHERDUCK=1
# MOTHERDUCK_TOKEN=

# Optional: Yelp DuckDB for yelp-analytics (defaults to DataAgentBench query_yelp yelp_user.db)
# YELP_USER_DUCKDB_URI=md:my_database
# YELP_DUCKDB_REVIEW_FQN=main.review
# MOTHERDUCK_TOKEN=
# When MOTHERDUCK_TOKEN is set, the app ATTACHes the local yelp_user.db as yelp_dab and reads yelp_dab.review

# DataAgentBench checkout (eval harness: eval/config.yaml + python -m eval.harness)
# If unset, eval looks for a sibling ../DataAgentBench from the repo root.
# DAB_ROOT=/path/to/DataAgentBench